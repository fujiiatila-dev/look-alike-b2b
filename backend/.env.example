# ====================================================================
# Variáveis de Ambiente - Freedom.ai B2B SaaS
# ====================================================================
# NUNCA commitar este arquivo com valores reais!
# Copie para .env e preencha os valores do seu ambiente.
# ====================================================================

# ── Modo do banco de dados: "mock" | "postgres" | "supabase"
DB_MODE=mock

# ── PostgreSQL (quando DB_MODE=postgres)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Supabase (quando DB_MODE=supabase)
# SUPABASE_URL=https://xyzcompany.supabase.co
# SUPABASE_KEY=your_anon_key

# ── JWT (para substituir o token mock)
# JWT_SECRET_KEY=sua_chave_secreta_muito_segura
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=480

# ── OpenAI (para OutreachDraftAgent em produção)
# OPENAI_API_KEY=sk-...

# ── Gemini (para OutreachDraftAgent em produção)
# GOOGLE_AI_API_KEY=AIza...

# ── Ambiente
APP_ENV=development
APP_PORT=8000
